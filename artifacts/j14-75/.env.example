# J14-75 Frontend Environment Variables

# API URL - Required for chatbot and email login to work
# This should point to your deployed API server
# For local development: http://localhost:3000
# For production: https://your-api-server.vercel.app (or your backend URL)
VITE_API_URL=http://localhost:3000

# Arc Testnet defaults used by frontend
VITE_ARC_RPC_URL=https://rpc.testnet.arc.network/
VITE_ARC_EXPLORER_URL=https://testnet.arcscan.app

# Optional: EURC Token Address override on Arc Testnet
VITE_ARC_EURC_ADDRESS=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a

# Optional: Blockscout API Key (not required for Arc Testnet)
# VITE_BLOCKSCOUT_API_KEY=your_key_here
