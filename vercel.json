{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/j14-75 build",
  "outputDirectory": "artifacts/j14-75/dist/public",
  "installCommand": "corepack enable && corepack prepare pnpm@10.3.0 --activate && pnpm install --frozen-lockfile",
  "functions": {
    "artifacts/api-server/src/vercel.ts": {
      "includeFiles": "artifacts/api-server/**/*"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/artifacts/api-server/src/vercel.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
