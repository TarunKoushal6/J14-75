{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"if(!process.env.npm_config_user_agent?.startsWith(\\\"pnpm/\\\")){console.error(\\\"Use pnpm instead\\\");process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "relay-webhook": "ts-node -T scripts/relay-webhook.ts",
    "relay-init": "node scripts/init-arc-relay.js",
    "relay-status": "ts-node -T scripts/relay-status.js",
    "relay-repair": "ts-node -T scripts/relay-repair.js"
  },
  "private": true,
  "devDependencies": {
    "@types/node": "catalog:",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1"
  },
  "packageManager": "pnpm@10.3.0"
}

